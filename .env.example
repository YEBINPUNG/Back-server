NODE_ENV=development
PORT=4000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/team_manager?schema=public

JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=14d

# LLM (OpenAI 호환 API). 무료 공급자 예시: Groq(https://console.groq.com/keys) 또는 Gemini.
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

AWS_REGION=ap-northeast-2
S3_BUCKET=team-manager-uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

CORS_ORIGIN=http://localhost:3000

# ── 배포(EC2 + Caddy) 전용 ──
# Caddy가 자동 HTTPS 인증서를 발급할 도메인. docker-compose가 이 값을 사용한다.
# 예: DOMAIN=myteam.duckdns.org
DOMAIN=

# 프로덕션 배포 시 주의:
#   NODE_ENV=production
#   JWT_ACCESS_SECRET / JWT_REFRESH_SECRET 는 반드시 길고 무작위인 값으로 교체
#     (예: `openssl rand -base64 48`)
#   CORS_ORIGIN 은 실제 프론트엔드 주소로 설정
