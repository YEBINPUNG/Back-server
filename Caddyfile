# DOMAIN 환경변수(.env)의 도메인으로 자동 HTTPS 인증서를 발급/갱신한다.
# 예: DOMAIN=myteam.duckdns.org
{$DOMAIN} {
	encode gzip

	# API 요청은 백엔드 컨테이너로 프록시 (경로 /api/v1/... 그대로 전달). 보안 헤더는 helmet이 처리.
	handle /api/* {
		reverse_proxy app:4000
	}

	# 헬스체크도 백엔드로
	handle /health {
		reverse_proxy app:4000
	}

	# 그 외 모든 경로는 정적 프론트엔드(SPA)를 서빙. 없는 경로는 index.html로 폴백.
	handle {
		# 정적 응답 보안 헤더 (클릭재킹/MIME 스니핑/리퍼러 노출 방지, 서버 정보 숨김)
		header {
			-Server
			X-Frame-Options "DENY"
			X-Content-Type-Options "nosniff"
			Referrer-Policy "no-referrer"
			Strict-Transport-Security "max-age=31536000"
		}
		root * /srv/frontend
		try_files {path} /index.html
		file_server
	}
}
