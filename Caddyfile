# DOMAIN 환경변수(.env)의 도메인으로 자동 HTTPS 인증서를 발급/갱신한다.
# 예: DOMAIN=myteam.duckdns.org
{$DOMAIN} {
	encode gzip

	# API 요청은 백엔드 컨테이너로 프록시 (경로 /api/v1/... 그대로 전달)
	handle /api/* {
		reverse_proxy app:4000
	}

	# 헬스체크도 백엔드로
	handle /health {
		reverse_proxy app:4000
	}

	# 그 외 모든 경로는 정적 프론트엔드(SPA)를 서빙. 없는 경로는 index.html로 폴백.
	handle {
		root * /srv/frontend
		try_files {path} /index.html
		file_server
	}
}
